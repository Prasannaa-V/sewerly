# Environment Configuration (Development)
# Copy this file to .env.local and update values for your environment

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_API_KEY=your_api_key_here

# WebSocket Configuration (for real-time data)
VITE_WS_URL=ws://localhost:8000/ws

# Feature Flags
VITE_ENABLE_REAL_DATA=false
VITE_ENABLE_MOCK_DATA=true
VITE_DEBUG_MODE=true

# Map Configuration (if using real maps)
VITE_MAP_KEY=your_map_key_here
VITE_MAP_PROVIDER=google  # google | mapbox | here

# Application
VITE_APP_TITLE=Smart Manhole Monitoring
VITE_DATA_REFRESH_INTERVAL=5000  # milliseconds
