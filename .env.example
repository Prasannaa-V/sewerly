# Dashboard Configuration

# Bridge API Configuration
VITE_SENSOR_API_BASE=http://localhost:3001

# API Key Authentication (REQ-003)
# Must match the API_KEY in the bridge server
# Only needed if REQUIRE_API_KEY=true on the bridge
VITE_API_KEY=your-secure-api-key-here

# Firebase Configuration (for direct Firestore access if needed)
